# DIGtv local environment — TEMPLATE (safe to commit). Copy to `.env` and fill in.
# The real `.env` is gitignored. This repo is PUBLIC — never put secrets here.

# ---- GitHub / git ----
# GitHub auth is provided by the `gh` CLI keyring (account: digunderground).
# No token is stored in a file; `git`/`gh` work via the macOS keychain.
GITHUB_OWNER=digunderground
GITHUB_REPO=jellyfin-digtv
GIT_REMOTE=https://github.com/digunderground/jellyfin-digtv.git
GIT_AUTHOR_NAME=digunderground
GIT_AUTHOR_EMAIL=digunderground@users.noreply.github.com
PLUGIN_GUID=b3f8e2a1-7c4d-4e6b-9a2f-1d5c8e0a4b7e
PLUGIN_REPO_MANIFEST_URL=https://raw.githubusercontent.com/digunderground/jellyfin-digtv/main/manifest.json

# ---- Jellyfin API (copy values from /code/_tools/Spotify Sync/.env) ----
JELLYFIN_URL=
JELLYFIN_API_KEY=
JELLYFIN_USERNAME=
JELLYFIN_USER_ID=
